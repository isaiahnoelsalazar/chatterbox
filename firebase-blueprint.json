{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName"]
    },
    "GlobalMessage": {
      "title": "Global Chat Message",
      "description": "A message sent in the public global chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "timestamp"]
    },
    "Connection": {
      "title": "User Connection",
      "description": "A friend request or established connection between two users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "status", "timestamp"]
    },
    "PrivateMessage": {
      "title": "Private Message",
      "description": "A one-on-one message between two users.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "chatId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "receiverId", "chatId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/global_messages/{messageId}": {
      "schema": "GlobalMessage",
      "description": "Public chat messages."
    },
    "/connections/{connectionId}": {
      "schema": "Connection",
      "description": "Friend requests and connections."
    },
    "/private_messages/{messageId}": {
      "schema": "PrivateMessage",
      "description": "Private chat messages."
    }
  }
}
